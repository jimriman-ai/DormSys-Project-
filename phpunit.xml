<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="vendor/phpunit/phpunit/phpunit.xsd"
         bootstrap="vendor/autoload.php"
         colors="true"
>
    <testsuites>
        <testsuite name="Unit">
            <directory>tests/Unit</directory>
        </testsuite>
        <testsuite name="Feature">
            <directory>tests/Feature</directory>
        </testsuite>
        <testsuite name="Architecture">
            <directory>tests/Architecture</directory>
        </testsuite>
        <!-- HD-02 Option B / G-REQ: run serially (GReqGuards then Hd02OptionB). Shared testing DB. -->
        <testsuite name="GReqGuards">
            <file>tests/Architecture/RequestTestApiGuardTest.php</file>
            <file>tests/Architecture/Stage1HelperContractTest.php</file>
            <file>tests/Architecture/RequestDomainBoundaryTest.php</file>
            <file>tests/Architecture/PresentationEventDispatchGuardTest.php</file>
            <file>tests/Architecture/PresentationCommandDispatchGuardTest.php</file>
            <file>tests/Architecture/PresentationRawQueryGuardTest.php</file>
            <file>tests/Architecture/PresentationServiceLocatorGuardTest.php</file>
            <file>tests/Feature/Modules/Request/RequestTransitionGuardTest.php</file>
        </testsuite>
        <testsuite name="Hd02OptionB">
            <file>tests/Feature/Modules/Lottery/LotteryProgramLifecycleTest.php</file>
            <file>tests/Feature/Modules/Lottery/LotteryFoundationTest.php</file>
            <file>tests/Unit/Modules/Lottery/Application/LotteryProgramActionsTest.php</file>
            <file>tests/Unit/Modules/Lottery/Domain/LotteryProgramEntityTest.php</file>
            <file>tests/Unit/Modules/Lottery/Domain/LotteryProgramStateTest.php</file>
            <file>tests/Unit/Modules/Lottery/Domain/LotteryProgramTransitionMatrixTest.php</file>
            <file>tests/Unit/Modules/Lottery/Domain/LotteryProgramLifecycleTest.php</file>
            <file>tests/Unit/Modules/Lottery/Domain/LotteryValueObjectsTest.php</file>
            <file>tests/Unit/Modules/Lottery/Domain/LotteryExceptionsTest.php</file>
            <file>tests/Unit/Modules/Lottery/Domain/LotteryScoringEngineTest.php</file>
            <file>tests/Unit/Modules/Lottery/Domain/LotteryDrawSelectorTest.php</file>
            <file>tests/Unit/Modules/Lottery/Domain/LockedLotterySemanticContractTest.php</file>
        </testsuite>
    </testsuites>
    <source>
        <include>
            <directory>app</directory>
        </include>
    </source>
    <php>
        <ini name="memory_limit" value="512M"/>
        <env name="APP_ENV" value="testing"/>
        <env name="APP_MAINTENANCE_DRIVER" value="file"/>
        <env name="BCRYPT_ROUNDS" value="4"/>
        <env name="BROADCAST_CONNECTION" value="null"/>
        <env name="CACHE_STORE" value="redis" force="true"/>
        <!-- Sail/container: service hostname (host-side 127.0.0.1 fails inside laravel.test) -->
        <env name="DB_HOST" value="pgsql"/>
        <env name="DB_PORT" value="5432"/>
        <env name="DB_DATABASE" value="testing"/>
        <env name="DB_USERNAME" value="sail"/>
        <env name="DB_PASSWORD" value="password"/>
        <env name="MAIL_MAILER" value="array"/>
        <env name="QUEUE_CONNECTION" value="redis" force="true"/>
        <env name="REDIS_CLIENT" value="predis" force="true"/>
        <!-- Sail/CI baseline (L8 1888/0). Host-side 127.0.0.1 belongs in local .env — not here; force keeps Sail hostname. -->
        <env name="REDIS_HOST" value="redis" force="true"/>
        <env name="REDIS_PASSWORD" value=""/>
        <env name="REDIS_PORT" value="6379" force="true"/>
        <env name="SESSION_DRIVER" value="array"/>
        <env name="PULSE_ENABLED" value="false"/>
        <env name="TELESCOPE_ENABLED" value="false"/>
        <env name="NIGHTWATCH_ENABLED" value="false"/>
        <env name="PERMISSION_TESTING" value="true"/>
        <env name="PERMISSION_CACHE_STORE" value="array" force="true"/>
    </php>
</phpunit>
